# .env.example — шаблон конфигурации для Числяндии
# Скопируй в .env или .env.local и заполни нужные поля

# === ОБЩИЕ НАСТРОЙКИ ===
LOG_LEVEL=INFO
DATABASE_URL=data/progress.db
ADMIN_IDS=5001966771,123456789
APP_ENV=development
BACKUP_KEEP_COUNT=14
SPAM_MIN_INTERVAL_SEC=0.45
SPAM_DUPLICATE_WINDOW_SEC=3.0
SPAM_WARN_INTERVAL_SEC=4.0

# === TELEGRAM (если используешь) ===
BOT_TOKEN=123456789:REPLACE_WITH_REAL_BOT_TOKEN
BOT_PLATFORM=telegram

# === VK / MAX (если используешь) ===
# Получить токен: Управление сообществом → Работа с API → Создать ключ
# Права: Сообщения, Управление сообществом, Фотографии
VK_TOKEN=REPLACE_WITH_REAL_VK_TOKEN
VK_API_VERSION=5.131
# ID сообщества: найди в URL группы или через https://vk.com/club236935995
VK_GROUP_ID=236935995

# === ДЛЯ ОДНОВРЕМЕННОГО ЗАПУСКА НА ОБОИХ ПЛАТФОРМАХ ===
# Просто заполни ОБА блока выше — бот запустится на обеих!